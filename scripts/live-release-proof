#!/usr/bin/env bash
# Run the complete terminal release proof from a normal, non-sandboxed shell.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

usage() {
  cat <<'EOF'
Usage: scripts/live-release-proof [--log-dir DIR]

Runs the complete terminal release proof with durable logs:
  1. Static release gates
  2. Redis IPC live gate
  3. Overmind process + IPC live gate
  4. Proof directory verification

This must run from a normal Terminal session, not the Codex sandbox.

Options:
  --log-dir DIR  Directory for proof logs. Defaults to .tmp/release-proof-<timestamp>.
  -h, --help     Show this help.
EOF
}

LOG_DIR=".tmp/release-proof-$(date +%Y%m%d-%H%M%S)"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --log-dir)
      shift
      LOG_DIR="${1:?missing value for --log-dir}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      LOG_DIR="$1"
      ;;
  esac
  shift
done

mkdir -p "$LOG_DIR"

write_manifest() {
  local manifest="$LOG_DIR/manifest.txt"
  {
    printf 'Agency terminal release proof manifest\n'
    printf 'Generated: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf 'Repository: %s\n' "$REPO_ROOT"
    printf 'Log directory: %s\n' "$LOG_DIR"
    printf 'Invocation: scripts/live-release-proof --log-dir %s\n' "$LOG_DIR"
    printf '\nExpected proof files:\n'
    printf '  manifest.txt\n'
    printf '  static.log\n'
    printf '  live-redis-ipc.log\n'
    printf '  live-overmind.log\n'
    printf '\nGate commands:\n'
    printf '  scripts/release-smoke --log %s/static.log\n' "$LOG_DIR"
    printf '  scripts/release-smoke --live --skip-static --log %s/live-redis-ipc.log\n' "$LOG_DIR"
    printf '  scripts/release-smoke --with-overmind --skip-static --log %s/live-overmind.log\n' "$LOG_DIR"
    printf '\nGit revision:\n'
    git rev-parse HEAD 2>/dev/null || true
    printf '\nGit status:\n'
    git status --short 2>/dev/null || true
    printf '\nTool versions:\n'
    go version 2>/dev/null || true
    redis-server --version 2>/dev/null || true
    overmind --version 2>/dev/null || true
    python3 --version 2>/dev/null || true
  } > "$manifest"
}

run_gate() {
  local name="$1"
  local log_file="$2"
  shift 2

  printf '\n== %s ==\n' "$name"
  printf 'Command: %s\n' "$*"
  printf 'Log: %s\n' "$log_file"

  if "$@" --log "$log_file"; then
    printf 'PASS: %s\n' "$name"
    return 0
  else
    local status=$?
    printf 'FAIL: %s exited with %s\n' "$name" "$status" >&2
    printf '\nLast log lines from %s:\n' "$log_file" >&2
    tail -80 "$log_file" >&2 || true
    return "$status"
  fi
}

cat <<EOF
Agency terminal release proof
Repository: $REPO_ROOT
Logs: $LOG_DIR

This command must run from a normal Terminal session. The Codex sandbox cannot
bind the Redis TCP port or the Overmind Unix socket required by the live gates.
EOF

write_manifest

run_gate "Static release gates" "$LOG_DIR/static.log" scripts/release-smoke
run_gate "Redis IPC live gate" "$LOG_DIR/live-redis-ipc.log" scripts/release-smoke --live --skip-static
run_gate "Overmind process + IPC live gate" "$LOG_DIR/live-overmind.log" scripts/release-smoke --with-overmind --skip-static

printf '\n== Proof verifier ==\n'
scripts/verify-release-proof "$LOG_DIR"

cat <<EOF

Agency terminal release proof passed and verified.
Logs:
  $LOG_DIR/manifest.txt
  $LOG_DIR/static.log
  $LOG_DIR/live-redis-ipc.log
  $LOG_DIR/live-overmind.log
EOF
