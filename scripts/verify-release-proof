#!/usr/bin/env bash
# Verify a completed scripts/live-release-proof evidence directory.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/verify-release-proof LOG_DIR

Checks that a terminal release proof directory contains the expected manifest
and successful gate logs from scripts/live-release-proof.
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

LOG_DIR="${1:-}"
if [ -z "$LOG_DIR" ]; then
  usage >&2
  exit 2
fi

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

require_file() {
  local file="$1"
  [ -s "$file" ] || fail "missing or empty file: $file"
}

require_text() {
  local file="$1"
  local text="$2"
  grep -Fq "$text" "$file" || fail "missing '$text' in $file"
}

reject_text() {
  local file="$1"
  local text="$2"
  if grep -Fq "$text" "$file"; then
    fail "unexpected '$text' in $file"
  fi
}

MANIFEST="$LOG_DIR/manifest.txt"
STATIC_LOG="$LOG_DIR/static.log"
REDIS_LOG="$LOG_DIR/live-redis-ipc.log"
OVERMIND_LOG="$LOG_DIR/live-overmind.log"

require_file "$MANIFEST"
require_file "$STATIC_LOG"
require_file "$REDIS_LOG"
require_file "$OVERMIND_LOG"

require_text "$MANIFEST" "Agency terminal release proof manifest"
require_text "$MANIFEST" "Invocation: scripts/live-release-proof --log-dir"
require_text "$MANIFEST" "static.log"
require_text "$MANIFEST" "live-redis-ipc.log"
require_text "$MANIFEST" "live-overmind.log"

require_text "$STATIC_LOG" "Static release gates passed."
require_text "$STATIC_LOG" "docker.enabled=false"

require_text "$REDIS_LOG" "Live Redis IPC gate passed."
require_text "$REDIS_LOG" "scripts/release-smoke --with-overmind"

require_text "$OVERMIND_LOG" "Release smoke passed."
require_text "$OVERMIND_LOG" "Redis IPC gate"

reject_text "$STATIC_LOG" "FAIL:"
reject_text "$REDIS_LOG" "FAIL:"
reject_text "$OVERMIND_LOG" "FAIL:"
reject_text "$STATIC_LOG" "bind: Operation not permitted"
reject_text "$REDIS_LOG" "bind: Operation not permitted"
reject_text "$OVERMIND_LOG" "bind: Operation not permitted"

echo "PASS: release proof verified at $LOG_DIR"
