#!/bin/bash
set -e
pip install kokoro-onnx soundfile numpy
mkdir -p .teamcode/agency/voice/models
# Download Kokoro ONNX model
MODEL_URL="https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files/kokoro-v1.0-q8f16.onnx"
VOICES_URL="https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files/voices.bin"
MODEL_PATH=".teamcode/agency/voice/models/model_q8f16.onnx"
VOICES_PATH=".teamcode/agency/voice/models/voices.bin"
if [ ! -f "$MODEL_PATH" ]; then
  echo "Downloading Kokoro model..."
  curl -L "$MODEL_URL" -o "$MODEL_PATH"
else
  echo "Model already present, skipping download."
fi
if [ ! -f "$VOICES_PATH" ]; then
  echo "Downloading Kokoro voices..."
  curl -L "$VOICES_URL" -o "$VOICES_PATH"
else
  echo "Voices already present, skipping download."
fi

cat > scripts/kokoro-tts.py << 'PYEOF'
#!/usr/bin/env python3
"""Kokoro TTS wrapper for Agency.

Usage:
  kokoro-tts.py --voice af_heart --output /tmp/out.wav --text "hello"
"""
import argparse
import json
import os
import sys

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--voice", default="af_heart")
    parser.add_argument("--output", default="/tmp/agency_tts_out.wav")
    parser.add_argument("--text", default="")
    args = parser.parse_args()

    text = args.text or sys.stdin.read()
    voice = args.voice
    output_path = args.output

    try:
        from kokoro_onnx import Kokoro
        import soundfile as sf

        repo_root = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
        model_path = os.path.join(repo_root, ".teamcode", "agency", "voice", "models", "model_q8f16.onnx")
        voices_path = os.path.join(repo_root, ".teamcode", "agency", "voice", "models", "voices.bin")
        kokoro = Kokoro(model_path, voices_path)
        samples, sample_rate = kokoro.create(text, voice=voice, speed=1.0, lang="en-us")
        sf.write(output_path, samples, sample_rate)
        print(json.dumps({"ok": True, "path": output_path}))
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}))
        sys.exit(1)

if __name__ == "__main__":
    main()
PYEOF

chmod +x scripts/kokoro-tts.py
echo "Voice install complete."
