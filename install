#!/usr/bin/env bash
# Agency one-command installer.
#
# Public usage:
#   curl -fsSL https://raw.githubusercontent.com/ETEllis/agency/main/install | bash
#
# Environment overrides:
#   AGENCY_INSTALL_DIR=$HOME/.agency
#   AGENCY_REPO_URL=https://github.com/ETEllis/agency.git
#   AGENCY_INSTALL_ASSUME_YES=true
#   AGENCY_INSTALL_SKIP_PROVIDER=true
#   AGENCY_INSTALL_NO_LAUNCH=true
set -euo pipefail

APP_NAME="Agency"
REPO_URL="${AGENCY_REPO_URL:-https://github.com/ETEllis/agency.git}"
INSTALL_ROOT="${AGENCY_INSTALL_DIR:-$HOME/.agency}"
SOURCE_DIR="$INSTALL_ROOT/src"
BIN_DIR="$INSTALL_ROOT/bin"
ASSUME_YES="${AGENCY_INSTALL_ASSUME_YES:-false}"
SKIP_PROVIDER="${AGENCY_INSTALL_SKIP_PROVIDER:-false}"
NO_LAUNCH="${AGENCY_INSTALL_NO_LAUNCH:-false}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

ok() { printf "  ${GREEN}OK${RESET} %s\n" "$*"; }
warn() { printf "  ${YELLOW}WARN${RESET} %s\n" "$*"; }
fail() { printf "  ${RED}ERR${RESET} %s\n" "$*" >&2; exit 1; }
hdr() { printf "\n${BOLD}%s${RESET}\n" "$*"; }

usage() {
  cat <<EOF
Usage: install [options]

Installs Agency from source, including local runtime dependencies where a
supported package manager is available.

Options:
  -y, --yes          Assume yes for dependency install prompts
  --skip-provider    Skip interactive provider setup
  --no-launch        Build only; do not launch the TUI after setup
  --dir DIR          Install root (default: $HOME/.agency)
  --repo URL         Git repo URL (default: $REPO_URL)
  -h, --help         Show this help
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -y|--yes)
      ASSUME_YES=true
      ;;
    --skip-provider)
      SKIP_PROVIDER=true
      ;;
    --no-launch)
      NO_LAUNCH=true
      ;;
    --dir)
      shift
      INSTALL_ROOT="${1:?missing value for --dir}"
      SOURCE_DIR="$INSTALL_ROOT/src"
      BIN_DIR="$INSTALL_ROOT/bin"
      ;;
    --repo)
      shift
      REPO_URL="${1:?missing value for --repo}"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $1"
      ;;
  esac
  shift
done

confirm() {
  local prompt="$1"
  if [ "$ASSUME_YES" = "true" ]; then
    return 0
  fi
  printf "%s [y/N] " "$prompt"
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

append_path_hint() {
  local shell_name
  shell_name="$(basename "${SHELL:-sh}")"
  local command="export PATH=\"$BIN_DIR:\$PATH\""
  local config_file=""

  case "$shell_name" in
    zsh)
      for f in "$HOME/.zshrc" "$HOME/.zshenv"; do
        [ -f "$f" ] && config_file="$f" && break
      done
      [ -z "$config_file" ] && config_file="$HOME/.zshrc"
      ;;
    bash)
      for f in "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
        [ -f "$f" ] && config_file="$f" && break
      done
      [ -z "$config_file" ] && config_file="$HOME/.bashrc"
      ;;
    fish)
      config_file="$HOME/.config/fish/config.fish"
      command="fish_add_path $BIN_DIR"
      mkdir -p "$(dirname "$config_file")"
      ;;
    *)
      config_file="$HOME/.profile"
      ;;
  esac

  if [[ ":$PATH:" == *":$BIN_DIR:"* ]]; then
    return 0
  fi

  touch "$config_file" 2>/dev/null || true
  if [ -w "$config_file" ] && ! grep -Fq "$BIN_DIR" "$config_file" 2>/dev/null; then
    {
      printf "\n# Agency\n"
      printf "%s\n" "$command"
    } >> "$config_file"
    ok "Added $BIN_DIR to PATH in $config_file"
  else
    warn "Add Agency to your PATH manually:"
    printf "  %s\n" "$command"
  fi
}

need_command_or_fail() {
  command -v "$1" >/dev/null 2>&1 || fail "$1 is required but was not found"
}

install_homebrew_if_missing() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi
  if [ "$(uname -s)" != "Darwin" ]; then
    return 1
  fi
  if ! confirm "Homebrew is required to install Go, Redis, and Overmind. Install Homebrew now?"; then
    fail "Homebrew is required on macOS for one-command dependency installation"
  fi
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
  command -v brew >/dev/null 2>&1 || fail "Homebrew install finished but brew is not on PATH"
}

install_macos_deps() {
  install_homebrew_if_missing
  hdr "[1/5] Installing macOS dependencies"
  local packages=()
  for pkg in git go redis overmind; do
    if ! brew list "$pkg" >/dev/null 2>&1; then
      packages+=("$pkg")
    fi
  done
  if [ "${#packages[@]}" -gt 0 ]; then
    brew install "${packages[@]}"
  else
    ok "git, go, redis, and overmind are already installed"
  fi
}

install_linux_deps() {
  hdr "[1/5] Checking Linux dependencies"
  if command -v brew >/dev/null 2>&1; then
    local packages=()
    for pkg in git go redis overmind; do
      if ! brew list "$pkg" >/dev/null 2>&1; then
        packages+=("$pkg")
      fi
    done
    if [ "${#packages[@]}" -gt 0 ]; then
      brew install "${packages[@]}"
    else
      ok "git, go, redis, and overmind are already installed"
    fi
    return 0
  fi

  local missing=()
  for cmd in git go redis-server overmind; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done
  if [ "${#missing[@]}" -gt 0 ]; then
    fail "Missing dependencies: ${missing[*]}. Install them, or install Homebrew/Linuxbrew and rerun this script."
  fi
  ok "required Linux dependencies are present"
}

clone_or_update_repo() {
  hdr "[2/5] Fetching Agency"
  mkdir -p "$INSTALL_ROOT" "$BIN_DIR"
  if [ -d "$SOURCE_DIR/.git" ]; then
    ok "Using existing checkout at $SOURCE_DIR"
    git -C "$SOURCE_DIR" fetch --prune origin
    git -C "$SOURCE_DIR" pull --ff-only
  elif [ -e "$SOURCE_DIR" ]; then
    fail "$SOURCE_DIR exists but is not a git checkout"
  else
    git clone "$REPO_URL" "$SOURCE_DIR"
  fi
}

install_deps() {
  case "$(uname -s)" in
    Darwin)
      install_macos_deps
      ;;
    Linux)
      install_linux_deps
      ;;
    *)
      fail "Unsupported OS: $(uname -s). Agency currently supports macOS and Linux shells."
      ;;
  esac
  need_command_or_fail git
  need_command_or_fail go
  need_command_or_fail redis-server
  need_command_or_fail overmind
}

run_setup() {
  hdr "[3/5] Building Agency"
  local setup_args=(--no-launch)
  if [ "$SKIP_PROVIDER" = "true" ]; then
    setup_args+=(--skip-provider)
  fi
  (cd "$SOURCE_DIR" && scripts/setup "${setup_args[@]}")

  ln -sf "$SOURCE_DIR/agency" "$BIN_DIR/agency"
  ln -sf "$SOURCE_DIR/teamcode" "$BIN_DIR/teamcode"
  ok "Installed launchers in $BIN_DIR"
}

provider_next_step() {
  hdr "[4/5] Provider"
  if [ "$SKIP_PROVIDER" = "true" ]; then
    warn "Provider setup was skipped"
    printf "  Run later: cd %s && scripts/setup\n" "$SOURCE_DIR"
  else
    printf "  Provider setup completed or was handled by scripts/setup.\n"
  fi
}

finish() {
  hdr "[5/5] Ready"
  append_path_hint
  printf "\nAgency installed at:\n"
  printf "  %s\n" "$SOURCE_DIR"
  printf "\nStart the runtime:\n"
  printf "  cd %s && overmind start\n" "$SOURCE_DIR"
  printf "\nRun the TUI:\n"
  printf "  agency\n"
  printf "\nVerify the release path:\n"
  printf "  cd %s && scripts/release-smoke --live\n" "$SOURCE_DIR"
  printf "\n"

  if [ "$NO_LAUNCH" = "true" ]; then
    return 0
  fi

  if confirm "Launch Agency now?"; then
    (cd "$SOURCE_DIR" && ./agency)
  fi
}

printf "\n${BOLD}Agency installer${RESET}\n"
printf "${DIM}Repository: %s${RESET}\n" "$REPO_URL"
printf "${DIM}Install root: %s${RESET}\n" "$INSTALL_ROOT"

install_deps
clone_or_update_repo
run_setup
provider_next_step
finish
