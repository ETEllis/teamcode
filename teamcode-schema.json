                  },
                  "localChatDefault": {
                    "type": "string"
                  },
                  "loopStrategy": {
                    "type": "string"
                  },
                  "maxWip": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "requiredGates": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "reviewRequired": {
                    "type": "boolean"
                  },
                  "reviewRouting": {
                    "type": "string"
                  },
                  "synthesisRouting": {
                    "type": "string"
                  },
                  "workspaceModeDefault": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "roles": {
                "description": "Ordered role definitions for the template",
                "items": {
                  "properties": {
                    "canSpawnSubagents": {
                      "type": "boolean"
                    },
                    "currentFocus": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "profile": {
                      "enum": [
                        "coder",
                        "task"
                      ],
