              "grok-3-beta",
              "vertexai.gemini-2.5-flash",
              "claude-4-sonnet",
              "gpt-4.1",
              "gpt-4.1-mini",
              "o3-mini",
              "openrouter.gpt-4o",
              "copilot.gemini-2.5-pro",
              "gpt-4.1-nano",
              "o1-mini",
              "o3",
              "o4-mini",
              "openrouter.o3-mini",
              "copilot.o4-mini",
              "o1-pro",
              "llama-3.3-70b-versatile",
              "deepseek-r1-distill-llama-70b",
              "azure.o1",
              "openrouter.gpt-4.1-mini",
              "openrouter.gemini-2.5-flash",
              "grok-3-mini-beta",
              "vertexai.gemini-2.5",
              "claude-3.5-sonnet",
              "o1",
              "azure.gpt-4.1",
              "copilot.gpt-3.5-turbo",
              "copilot.claude-sonnet-4",
