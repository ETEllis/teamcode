                    },
                    "prompt": {
                      "type": "string"
                    },
                    "reportsTo": {
                      "type": "string"
                    },
                    "responsible": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "spawnTeammates": {
                "description": "Whether bootstrap should spawn teammate sessions immediately",
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "description": "User-defined or overridden collaboration templates",
          "type": "object"
        }
      },
      "type": "object"
