  "description": "Configuration schema for the Agency application",
  "properties": {
    "agency": {
      "description": "Agency office and runtime configuration",
      "properties": {
        "constitutions": {
          "additionalProperties": {
            "properties": {
              "blueprint": {
                "type": "string"
              },
              "defaultSchedule": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "entryMode": {
                "type": "string"
              },
              "governance": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "policies": {
                "properties": {
                  "consensusMode": {
                    "type": "string"
                  },
                  "defaultQuorum": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "publicationPolicy": {
                    "type": "string"
                  },
                  "spawnMode": {
                    "type": "string"
                  },
                  "wakeMode": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "runtimeMode": {
                "type": "string"
              },
              "teamTemplate": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "description": "Named constitutions that unify solo compatibility behavior and Agency office behavior",
          "type": "object"
        },
        "currentConstitution": {
          "default": "coding-office",
          "description": "Currently selected constitution for Agency product paths",
          "type": "string"
        },
        "docker": {
          "description": "Docker topology settings for the shared office runtime",
          "properties": {
            "composeFile": {
              "type": "string"
            },
            "composeProject": {
              "type": "string"
            },
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "image": {
              "type": "string"
            },
            "network": {
              "type": "string"
            },
            "sharedVolume": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "enabled": {
          "default": false,
          "description": "Whether Agency office features should be considered active for product surfaces",
          "type": "boolean"
        },
        "genesis": {
          "description": "Genesis defaults for intent-driven organization creation",
          "properties": {
            "autoResearch": {
              "default": true,
              "type": "boolean"
            },
            "autoSkills": {
              "default": true,
              "type": "boolean"
            },
            "autoToolBinding": {
              "default": true,
              "type": "boolean"
            },
            "conversationDriven": {
              "default": true,
              "type": "boolean"
            },
            "defaultTopology": {
              "default": "hierarchical",
              "type": "string"
            },
            "sequentialSpawn": {
              "default": true,
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "ledger": {
          "description": "Append-only ledger and context projection settings",
          "properties": {
            "backend": {
              "default": "append-only-log",
              "type": "string"
            },
            "consensusMode": {
              "default": "distributed-consensus",
              "type": "string"
            },
            "defaultQuorum": {
              "default": 2,
              "minimum": 1,
              "type": "integer"
            },
            "path": {
              "type": "string"
            },
            "projectionFile": {
              "type": "string"
            },
            "snapshotPath": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "office": {
          "description": "Shared office runtime settings",
          "properties": {
            "allowSoloFallback": {
              "default": true,
              "type": "boolean"
            },
            "autoBoot": {
              "default": false,
              "type": "boolean"
            },
            "defaultWorkspaceMode": {
              "default": "shared",
              "description": "Default workspace mode for agents in the office",
              "type": "string"
            },
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "mode": {
              "default": "distributed-office",
              "description": "Office runtime mode",
              "type": "string"
            },
            "sharedWorkplace": {
              "description": "Shared office filesystem root for Agency",
              "type": "string"
            },
            "stateFile": {
              "description": "Persistent file storing office runtime status across CLI invocations",
              "type": "string"
            }
          },
          "type": "object"
        },
        "productName": {
          "default": "The Agency",
          "description": "Public-facing product identity for the runtime",
          "type": "string"
        },
        "redis": {
          "description": "Redis event bus settings for the Agency office",
          "properties": {
            "address": {
              "default": "127.0.0.1:6379",
              "type": "string"
            },
            "channelPrefix": {
              "default": "agency",
              "type": "string"
            },
            "db": {
              "default": 7,
              "minimum": 0,
              "type": "integer"
            },
            "enabled": {
              "default": true,
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "schedules": {
          "description": "Office-hour and shift defaults for persistent organizations",
          "properties": {
            "defaultCadence": {
              "default": "weekday-office-hours",
              "type": "string"
            },
            "requireShiftHandoff": {
              "default": true,
              "type": "boolean"
            },
            "timezone": {
              "default": "local",
              "type": "string"
            },
            "wakeOnOfficeOpen": {
              "default": true,
              "type": "boolean"
            },
            "windows": {
              "items": {
                "properties": {
                  "days": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "end": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "start": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "soloConstitution": {
          "default": "solo",
          "description": "Constitution that preserves the solo compatibility workflow",
          "type": "string"
        }
      },
      "type": "object"
    },
